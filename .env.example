# Supabase — frontend (safe to expose; these ship to the browser)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Supabase — server / migrations only (NEVER prefix with VITE_, never commit)
# Used by scripts to run SQL migrations against the database.
SUPABASE_DB_HOST=db.YOUR_PROJECT.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=postgres
SUPABASE_DB_NAME=postgres
SUPABASE_DB_PASSWORD=your-database-password
